# Enable gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
  AddOutputFilterByType DEFLATE text/plain text/xml application/xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType application/font-woff2 "access plus 1 month"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"
  Header set Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; frame-ancestors 'self'; object-src 'none'; img-src 'self' data: https:; connect-src 'self' http://localhost:* http://127.0.0.1:* https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; font-src 'self' data: https:"
</IfModule>

# Prevent directory listing
Options -Indexes

# Default charset
AddDefaultCharset UTF-8

# -------------------------------------------------------------------
# Routing
# - Marketing site (React build output) lives in /public
# - Laravel API lives in /backend/public and should answer /api/*
# -------------------------------------------------------------------

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /visuallearn/

  # Preserve Authorization header for the Laravel API rewrite below.
  # Without this, Apache strips Bearer tokens before reaching Laravel.
  RewriteCond %{HTTP:Authorization} .
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  # Canonical auth URL: keep only student app login.
  RewriteRule ^(?:login|register)$ backend/public/app/login [R=302,L]
  RewriteRule ^backend/public/app/register$ backend/public/app/login [R=302,L]
  RewriteRule ^backend/public/admin/login$ backend/public/app/login [R=302,L]
  RewriteRule ^(?:index\.html|landing\.html|app\.html)$ public/index.html [R=302,L]
  RewriteRule ^marketing/?$ public/index.html [R=302,L]

  # Serve the marketing site on the project root.
  RewriteRule ^$ public/index.html [L]

  # Route API calls into Laravel (backend/).
  RewriteRule ^api(?:/.*)?$ backend/public/index.php [L,QSA]
</IfModule>
