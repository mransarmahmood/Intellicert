# Production deploy gitignore (production branch only).
# vendor/ IS committed here so Hostinger shared hosting can serve Laravel
# without running composer install. .env is NOT committed; create it on
# the server (see DEPLOY.md).

.env
.env.local
.env.backup
.env.production
storage/logs/*.log
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
!storage/framework/cache/data/.gitkeep
!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep
storage/*.key

# Build/dev only
node_modules/
.phpunit.cache
.phpunit.result.cache
public/build
public/hot
public/storage
.phpactor.json
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
auth.json

# IDE
.fleet/
.idea/
.nova/
.vscode/
.zed/
