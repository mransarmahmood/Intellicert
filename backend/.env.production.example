APP_NAME=IntelliCert
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.com

# Frontend hint (used by emails / redirects, not CORS)
FRONTEND_URL=https://your-domain.com

# Comma-separated list of full origins allowed by CORS.
# REQUIRED in production. With APP_ENV=production, an empty value denies all
# cross-origin requests. Same-origin requests (SPAs served from this domain)
# are unaffected.
CORS_ALLOWED_ORIGINS=https://your-domain.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Sessions
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=csp_studyhub
DB_USERNAME=csp_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

SESSION_DRIVER=file
SESSION_LIFETIME=120

# AI integration (Groq for Feynman teach-back)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DEEPAI_API_KEY=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
YOUTUBE_API_KEY=

# Legacy PHP endpoint compatibility. Set only if legacy files are served.
LEGACY_CORS_ALLOWED_ORIGINS=https://your-domain.com
LEGACY_DB_HOST=
LEGACY_DB_DATABASE=
LEGACY_DB_USERNAME=
LEGACY_DB_PASSWORD=

# Stripe — STRIPE_WEBHOOK_SECRET is REQUIRED if webhook-stripe endpoint is exposed.
# Without it, the webhook handler will return 500 (fail closed) to prevent
# attackers from forging payment events.
# STRIPE_KEY=
# STRIPE_SECRET=
# STRIPE_WEBHOOK_SECRET=
